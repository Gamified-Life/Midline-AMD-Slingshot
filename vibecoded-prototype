async function exportPDF(legalData, idea) {
  if (!legalData) return alert("Legal data not available yet.");
  const content = `
LEGAL FRAMEWORK FOR: ${idea.toUpperCase()}
Generated by Tailwind AI

═══════════════════════════════════════════════════

RECOMMENDED BUSINESS STRUCTURE
${legalData.businessStructure?.recommended}
${legalData.businessStructure?.reason}

${legalData.sections?.map((s) =>
  `\n${s.title.toUpperCase()}\n${"─".repeat(40)}\n${s.items?.map((i) => `  □ ${i}`).join("\n")}`
).join("\n")}

═══════════════════════════════════════════════════
URGENT ACTIONS
${legalData.urgentWarnings?.map((w) => `⚠ ${w}`).join("\n")}

═══════════════════════════════════════════════════
DISCLAIMER: This is AI-generated guidance for informational purposes only.
Please consult a qualified attorney before making legal decisions.
  `;
  const blob = new Blob([content], { type: "text/plain" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "legal-framework.txt";
  a.click();
}

