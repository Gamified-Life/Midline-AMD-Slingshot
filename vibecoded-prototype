  const addLog = (msg, done = false) =>
    setLog((l) => {
      const last = l[l.length - 1];
      if (last && !last.done) return [...l.slice(0, -1), { msg, done }];
      return [...l, { msg, done }];
    });

  useEffect(() => {
    if (started.current) return;
    started.current = true;
    run();
  }, []);

  const run = async () => {
    const qaText = offerData.questions
      .map((q) => `${q.question}: ${offerData.answers[q.id] || "N/A"}`)
      .join("\n");

